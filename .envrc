use flake

# Load local, uncommitted overrides first (if present). Anything you set in
# .envrc.local (e.g. plain `export LASTFM_EDIT_PASSWORD=...`) takes precedence
# over the `pass`-based defaults below.
if [ -f .envrc.local ]; then
  source_env .envrc.local
fi

# Defaults sourced from `pass`. These only apply if the variable isn't already
# set (e.g. from .envrc.local or the surrounding environment), so users without
# this exact `pass` setup can override them without editing this file.
: "${LASTFM_EDIT_USERNAME:=IvanMalison}"
export LASTFM_EDIT_USERNAME

if [ -z "${LASTFM_EDIT_PASSWORD:-}" ]; then
  export LASTFM_EDIT_PASSWORD="$(pass show last.fm | head -n 1)"
fi

if [ -z "${LASTFM_EDIT_API_KEY:-}" ]; then
  export LASTFM_EDIT_API_KEY="$(pass show last.fm | grep api-key | cut -d' ' -f2)"
fi
